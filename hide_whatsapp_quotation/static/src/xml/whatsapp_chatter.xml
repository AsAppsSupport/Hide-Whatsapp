<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="mail.Chatter"
       t-inherit-mode="extension">
        <xpath expr="//button[@t-on-click='sendWhatsapp']"
               position="replace">
            <button t-if="state.thread.canSendWhatsapp and !hideWhatsapp.value"
                    class="btn btn-secondary text-nowrap me-1"
                    t-att-class="{'my-2': !props.compactHeight }"
                    data-hotkey="shift+w"
                    t-on-click="sendWhatsapp">
                <span>WhatsApp</span>
            </button>
        </xpath>
    </t>
</templates>